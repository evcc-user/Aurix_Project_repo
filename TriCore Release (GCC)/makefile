# Main-build Target
main-build: V6_V4_TCPIP.elf secondary-outputs

# Tool invocations
V6_V4_TCPIP.elf: $(OBJS) ../Lcf_Gnuc_Tricore_Tc.lsl makefile $(OPTIONAL_TOOL_DEPS) .V6_V4_TCPIP.elf.opt
	@echo 'Building target: $@'
	@echo 'Invoking: AURIX GCC Linker'
	tricore-elf-gcc @.V6_V4_TCPIP.elf.opt
	@echo 'Finished building target: $@'
	@echo ' '

.V6_V4_TCPIP.elf.opt:
	$(file >$@, -T"../Lcf_Gnuc_Tricore_Tc.lsl" -nocrt0 -Wl,--gc-sections -mtc162 -o "V6_V4_TCPIP.elf" $(OBJS))

.PHONY: .V6_V4_TCPIP.elf.opt

V6_V4_TCPIP.hex: V6_V4_TCPIP.elf makefile $(OPTIONAL_TOOL_DEPS)
	@echo 'Invoking: AURIX Object Copy'
	tricore-elf-objcopy -O ihex "V6_V4_TCPIP.elf" "V6_V4_TCPIP.hex"
	@echo 'Finished building: $@'
	@echo ' '

V6_V4_TCPIP.lst: V6_V4_TCPIP.elf makefile $(OPTIONAL_TOOL_DEPS)
	@echo 'Invoking: AURIX Create Listing'
	tricore-elf-objdump -h -S "V6_V4_TCPIP.elf" > "V6_V4_TCPIP.lst"
	@echo 'Finished building: $@'
	@echo ' '

V6_V4_TCPIP.siz: V6_V4_TCPIP.elf makefile $(OPTIONAL_TOOL_DEPS)
	@echo 'Invoking: AURIX Print Size'
	tricore-elf-size  --format=berkeley "V6_V4_TCPIP.elf"
	@echo 'Finished building: $@'
	@echo ' '

# Other Targets
clean:
	-$(RM) V6_V4_TCPIP.elf V6_V4_TCPIP.hex V6_V4_TCPIP.lst V6_V4_TCPIP.siz
	-@echo ' '

